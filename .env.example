# ── Hybreed API configuration ─────────────────────────────────────────────
# Copy to `.env` for local development (loaded automatically when ENV != production).

# App
ENV=development                 # development | production
HTTP_ADDR=:8080
LOG_LEVEL=debug                 # debug | info | warn | error

# Postgres
DATABASE_URL=postgres://hybreed:hybreed@localhost:5432/hybreed?sslmode=disable
AUTO_MIGRATE=true               # run embedded migrations on startup

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=dev-only-change-me-to-a-long-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h          # 30 days
OTP_TTL=10m
OTP_MAX_ATTEMPTS=5
OTP_DEV_BYPASS_CODE=000000      # dev-only: verifies any account while no mail provider is wired (ignored when ENV=production; set empty to disable)

# CORS (comma-separated; * allows all — fine for the Expo dev client)
CORS_ALLOWED_ORIGINS=*
